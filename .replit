modules = ["python-3.11"]
run = "gunicorn app:app --bind 0.0.0.0:$PORT --workers 1 --threads 4 --timeout 120"

[nix]
channel = "stable-24_05"

[env]
PORT = "5000"

[deployment]
run = ["sh", "-c", "gunicorn app:app --bind 0.0.0.0:$PORT --workers 1 --threads 4 --timeout 120"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 5000
externalPort = 80
